generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Pack {
  id               String             @id
  subject          String             @default("chinese")
  name             String
  nameZh           String?
  emoji            String
  color            String
  sortOrder        Int                @default(0)
  words            Word[]
  sentences        Sentence[]
  problems         MathProblem[]
  chineseProgress  ChineseProgress[]
  sentenceProgress SentenceProgress[]
  mathProgress     MathProgress[]
  answerEvents     AnswerEvent[]

  @@index([subject])
}

model Word {
  id              String            @id
  packId          String
  english         String
  chinese         String
  pinyin          String
  image           String
  sortOrder       Int               @default(0)
  pack            Pack              @relation(fields: [packId], references: [id])
  chineseProgress ChineseProgress[]
}

/// Sentence practice for building basic language skills
model Sentence {
  id               String             @id
  packId           String
  english          String
  chinese          String
  pinyin           String
  sortOrder        Int                @default(0)
  pack             Pack               @relation(fields: [packId], references: [id])
  sentenceProgress SentenceProgress[]
}

/// Math topics store problems here — one row per arithmetic fact
model MathProblem {
  id           String         @id
  packId       String
  operand1     Int
  operator     String         // "+" | "-" | "count"
  operand2     Int
  answer       Int
  emoji        String
  sortOrder    Int            @default(0)
  pack         Pack           @relation(fields: [packId], references: [id])
  mathProgress MathProgress[]
}

/// Replaces WordProgress for Chinese — adds proper FK integrity
model ChineseProgress {
  id          String   @id @default(cuid())
  childName   String   @default("julian")
  packId      String
  pack        Pack     @relation(fields: [packId], references: [id])
  wordId      String
  word        Word     @relation(fields: [wordId], references: [id])
  easiness    Float    @default(2.5)
  interval    Int      @default(1)
  repetitions Int      @default(0)
  nextReview  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([childName, packId, wordId])
  @@index([childName, packId])
  @@map("WordProgress")
}

/// Sentence practice progress — SM-2 spaced repetition for sentences
model SentenceProgress {
  id          String   @id @default(cuid())
  childName   String   @default("julian")
  packId      String
  pack        Pack     @relation(fields: [packId], references: [id])
  sentenceId  String
  sentence    Sentence @relation(fields: [sentenceId], references: [id])
  easiness    Float    @default(2.5)
  interval    Int      @default(1)
  repetitions Int      @default(0)
  nextReview  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([childName, packId, sentenceId])
  @@index([childName, packId])
}

/// Math SM-2 progress — full FK to MathProblem
model MathProgress {
  id          String      @id @default(cuid())
  childName   String      @default("julian")
  packId      String
  pack        Pack        @relation(fields: [packId], references: [id])
  problemId   String
  problem     MathProblem @relation(fields: [problemId], references: [id])
  easiness    Float       @default(2.5)
  interval    Int         @default(1)
  repetitions Int         @default(0)
  nextReview  DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([childName, packId, problemId])
  @@index([childName, packId])
}

model AnswerEvent {
  id         String   @id @default(cuid())
  childName  String   @default("julian")
  packId     String
  pack       Pack     @relation(fields: [packId], references: [id])
  itemId     String   @map("wordId")
  correct    Boolean
  answeredAt DateTime @default(now())

  @@index([childName, packId, itemId])
  @@index([answeredAt])
}

model ChildProfile {
  name          String    @id
  totalHearts   Int       @default(0)
  streak        Int       @default(0)
  lastPracticed DateTime?
  updatedAt     DateTime  @updatedAt
}

/// Pre-generated exercise questions. AI runs once during setup; sessions just read from here.
model GeneratedQuestion {
  id          String   @id @default(cuid())
  packId      String
  wordId      String
  type        String
  distractors Json
  createdAt   DateTime @default(now())

  @@index([packId, wordId])
}
