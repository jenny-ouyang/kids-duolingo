generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WordProgress {
  id          String   @id @default(cuid())
  childName   String   @default("julian")
  packId      String
  wordId      String
  easiness    Float    @default(2.5)
  interval    Int      @default(1)
  repetitions Int      @default(0)
  nextReview  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([childName, packId, wordId])
  @@index([childName, packId])
}

model AnswerEvent {
  id         String   @id @default(cuid())
  childName  String   @default("julian")
  packId     String
  wordId     String
  correct    Boolean
  answeredAt DateTime @default(now())

  @@index([childName, packId, wordId])
  @@index([answeredAt])
}

model ChildProfile {
  name          String    @id
  totalHearts   Int       @default(0)
  streak        Int       @default(0)
  lastPracticed DateTime?
  updatedAt     DateTime  @updatedAt
}

model Pack {
  id        String @id
  name      String
  nameZh    String
  emoji     String
  color     String
  sortOrder Int    @default(0)
  words     Word[]
}

model Word {
  id        String @id
  packId    String
  english   String
  chinese   String
  pinyin    String
  image     String
  sortOrder Int    @default(0)
  pack      Pack   @relation(fields: [packId], references: [id])
}

/// Pre-generated exercise questions. AI runs once during setup; sessions just read from here.
model GeneratedQuestion {
  id          String   @id @default(cuid())
  packId      String
  wordId      String   // the correct-answer word
  type        String   // 'audio_to_picture' | 'picture_to_chinese' | 'english_to_chinese'
  distractors Json     // Word[] — snapshot of the 3 wrong-answer options
  createdAt   DateTime @default(now())

  @@index([packId, wordId])
}
